# C1 — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# Anthropic (required for message generation)
ANTHROPIC_API_KEY=sk-ant-...

# SMTP (required for email sending)
SMTP_USER=you@yourdomain.com
SMTP_PASS=your_app_password
SENDER_NAME=Jan Kowalski
SENDER_COMPANY=YourCompany

# Value proposition (used in message generation)
VALUE_PROPOSITION=Pomagamy firmom SaaS w Polsce pozyskać pierwszych 50 klientów bez cold calling

# LinkedIn data provider (optional)
LINKEDIN_PROVIDER=mock
PROXYCURL_API_KEY=
APOLLO_API_KEY=

# Enrichment (optional)
CLEARBIT_API_KEY=
HUNTER_API_KEY=

# Tracking (optional — your own domain)
TRACKING_DOMAIN=https://track.yourdomain.com
UNSUBSCRIBE_URL=https://yourdomain.com/unsubscribe
